---
import BaseLayout from '@/layouts/BaseLayout.astro';

const values = [
  { number: '01', title: 'Restraint',  body: 'We believe in the power of less. Every piece is stripped to its essence — no excess, no noise. Only what is necessary.' },
  { number: '02', title: 'Longevity',  body: 'The Void is not seasonal. We design for decades, not trends. Each garment is built to outlast the moment it was made in.' },
  { number: '03', title: 'Silence',    body: 'In a world of constant signal, we offer quiet. Clothes that speak without speaking. Presence without performance.' },
];
---

<BaseLayout title="About — The Void">

  <section class="pt-28 md:pt-36 container-void pb-24">

    <!-- Opening statement -->
    <div id="about-intro" class="max-w-2xl mb-20 md:mb-32">
      <p class="label-caps text-void-midnight mb-6">The Void — Est. 2024</p>
      <h1 class="heading-display text-display-lg text-void-white leading-tight mb-8">
        We make clothes<br />for those who<br />need nothing.
      </h1>
      <p class="text-void-muted text-sm font-light leading-relaxed max-w-sm">
        The Void began as a rejection — of noise, of excess, of fashion for its own sake. What remained was a question: what does clothing look like when it has nothing to prove?
      </p>
    </div>

    <!-- Divider -->
    <div id="divider-1" class="w-full h-px bg-void-border mb-20 md:mb-32"></div>

    <!-- Manifesto -->
    <div id="about-manifesto" class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 mb-20 md:mb-32">
      <div>
        <p class="label-caps text-void-muted mb-6">Manifesto</p>
        <p class="heading-display text-display-md text-void-white mb-0">
          "Silence<br />as a<br />statement."
        </p>
      </div>
      <div class="flex flex-col justify-end gap-6">
        <p class="text-void-muted text-sm font-light leading-relaxed">
          The modern wardrobe is cluttered with intention — pieces bought to signal status, mood, belonging. We are not interested in signals.
        </p>
        <p class="text-void-muted text-sm font-light leading-relaxed">
          The Void is for people who have arrived. Who no longer need their clothes to speak for them. Who choose restraint not from lack, but from abundance of certainty.
        </p>
        <p class="text-void-muted text-sm font-light leading-relaxed">
          We make things that last. Quietly. Deliberately. Without apology.
        </p>
      </div>
    </div>

    <!-- Divider -->
    <div id="divider-2" class="w-full h-px bg-void-border mb-20 md:mb-32"></div>

    <!-- Values -->
    <div id="about-values" class="mb-20 md:mb-32">
      <p class="label-caps text-void-muted mb-12">What we stand for</p>
      <div class="flex flex-col divide-y divide-void-border">
        {values.map(v => (
          <div class="value-item grid grid-cols-1 md:grid-cols-[120px_1fr_1fr] gap-4 md:gap-12 py-10">
            <p class="label-caps text-void-border">{v.number}</p>
            <h3 class="heading-display text-display-md text-void-white">{v.title}</h3>
            <p class="text-void-muted text-sm font-light leading-relaxed self-end">{v.body}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Divider -->
    <div id="divider-3" class="w-full h-px bg-void-border mb-20 md:mb-32"></div>

    <!-- Closing + CTA -->
    <div id="about-closing" class="grid grid-cols-1 md:grid-cols-2 gap-12 items-end">
      <div>
        <p class="label-caps text-void-muted mb-6">The collection</p>
        <p class="heading-display text-display-md text-void-white mb-8">
          Explore<br />the void.
        </p>
        <div class="flex flex-col xs:flex-row gap-3">
          <a href="/shop" class="btn-void text-center">Shop Now</a>
          <a href="/lookbook" class="btn-void-ghost text-center">View Lookbook</a>
        </div>
      </div>
      <div class="aspect-[4/3] bg-void-surface"></div>
    </div>

  </section>

</BaseLayout>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // ── Page entrance ────────────────────────────────────
  const intro = document.getElementById('about-intro');
  requestAnimationFrame(() => requestAnimationFrame(() => {
    gsap.set(intro, { opacity: 0, y: 32 });
    gsap.to(intro, { opacity: 1, y: 0, duration: 1.2, ease: 'power2.out' });
  }));

  // ── Scroll animations ────────────────────────────────
  const scrollEls = ['#divider-1', '#about-manifesto', '#divider-2', '#about-values', '#divider-3', '#about-closing'];
  scrollEls.forEach(sel => {
    const el = document.querySelector(sel);
    if (!el) return;
    gsap.set(el, { opacity: 0, y: 24 });
    gsap.to(el, {
      opacity: 1, y: 0,
      duration: 1.0,
      ease: 'power2.out',
      scrollTrigger: { trigger: el, start: 'top 85%', once: true },
    });
  });

  // ── Value items stagger ──────────────────────────────
  document.querySelectorAll('.value-item').forEach((el, i) => {
    gsap.set(el, { opacity: 0, y: 20 });
    gsap.to(el, {
      opacity: 1, y: 0,
      duration: 0.8,
      ease: 'power2.out',
      delay: i * 0.1,
      scrollTrigger: { trigger: el, start: 'top 88%', once: true },
    });
  });

  // ── Divider line reveal ──────────────────────────────
  ['#divider-1', '#divider-2', '#divider-3'].forEach(sel => {
    const el = document.querySelector(sel) as HTMLElement;
    if (!el) return;
    gsap.set(el, { scaleX: 0, transformOrigin: 'left' });
    gsap.to(el, {
      scaleX: 1,
      duration: 1.2,
      ease: 'power2.inOut',
      scrollTrigger: { trigger: el, start: 'top 90%', once: true },
    });
  });
</script>
