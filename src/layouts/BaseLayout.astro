---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'The Void — Minimal Fashion',
  description = 'Crafted for those who find beauty in restraint.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <!-- Navbar -->
    <header id="navbar" class="fixed top-0 left-0 right-0 z-50 border-b border-void-border/40 bg-void-black/90 backdrop-blur-sm">
      <div class="container-void">
        <nav class="flex items-center justify-between h-14 md:h-16">

          <!-- Logo -->
          <a href="/" class="heading-display text-xl md:text-2xl text-void-white tracking-widest">
            THE VOID
          </a>

          <!-- Desktop links -->
          <ul class="hidden md:flex items-center gap-8">
            <li><a href="/shop"     class="label-caps text-void-muted hover:text-void-white transition-colors duration-300">Shop</a></li>
            <li><a href="/lookbook" class="label-caps text-void-muted hover:text-void-white transition-colors duration-300">Lookbook</a></li>
            <li><a href="/about"    class="label-caps text-void-muted hover:text-void-white transition-colors duration-300">About</a></li>
          </ul>

          <!-- Right actions -->
          <div class="flex items-center gap-4 md:gap-6">
            <button aria-label="Search" class="text-void-muted hover:text-void-white transition-colors duration-300">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.35-4.35"/></svg>
            </button>
            <a href="/cart" aria-label="Cart" class="relative text-void-muted hover:text-void-white transition-colors duration-300">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
              <span id="cart-badge" class="hidden absolute -top-1.5 -right-1.5 w-4 h-4 bg-void-white text-void-black text-[9px] font-medium rounded-full flex items-center justify-center leading-none"></span>
            </a>

            <!-- Mobile menu button -->
            <button id="menu-toggle" aria-label="Menu" class="md:hidden text-void-muted hover:text-void-white transition-colors duration-300">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><line x1="3" y1="6"  x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
          </div>

        </nav>
      </div>

      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden border-t border-void-border/40 bg-void-black">
        <ul class="container-void py-6 flex flex-col gap-5">
          <li><a href="/shop"     class="label-caps text-void-muted hover:text-void-white transition-colors duration-300">Shop</a></li>
          <li><a href="/lookbook" class="label-caps text-void-muted hover:text-void-white transition-colors duration-300">Lookbook</a></li>
          <li><a href="/about"    class="label-caps text-void-muted hover:text-void-white transition-colors duration-300">About</a></li>
        </ul>
      </div>
    </header>

    <!-- Page content -->
    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-void-border mt-24">
      <div class="container-void py-12 md:py-16">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
          <div class="col-span-2 md:col-span-1">
            <p class="heading-display text-xl text-void-white tracking-widest mb-3">THE VOID</p>
            <p class="text-void-muted text-sm font-light leading-relaxed">Crafted for those who find beauty in restraint.</p>
          </div>
          <div>
            <p class="label-caps text-void-muted mb-4">Shop</p>
            <ul class="space-y-2">
              {['Tops', 'Bottoms', 'Outerwear', 'Knitwear', 'Bags', 'Jewelry', 'Belts'].map(c => (
                <li><a href="/shop" class="text-void-muted text-sm hover:text-void-white transition-colors duration-300">{c}</a></li>
              ))}
            </ul>
          </div>
          <div>
            <p class="label-caps text-void-muted mb-4">Info</p>
            <ul class="space-y-2">
              <li><a href="/about"    class="text-void-muted text-sm hover:text-void-white transition-colors duration-300">About</a></li>
              <li><a href="/lookbook" class="text-void-muted text-sm hover:text-void-white transition-colors duration-300">Lookbook</a></li>
              <li><span class="text-void-muted/40 text-sm cursor-default">Shipping</span></li>
              <li><span class="text-void-muted/40 text-sm cursor-default">Returns</span></li>
            </ul>
          </div>
          <div>
            <p class="label-caps text-void-muted mb-4">Follow</p>
            <ul class="space-y-2">
              {['Instagram', 'Pinterest', 'TikTok'].map(s => (
                <li><a href="#" class="text-void-muted text-sm hover:text-void-white transition-colors duration-300">{s}</a></li>
              ))}
            </ul>
          </div>
        </div>
        <div class="border-t border-void-border pt-6 flex flex-col sm:flex-row justify-between gap-3">
          <p class="label-caps text-void-muted/60">© 2026 The Void. All rights reserved.</p>
          <p class="label-caps text-void-muted/40">Privacy · Terms</p>
        </div>
      </div>
    </footer>

    <script>
      import { initLenis, initNavbar } from '@/lib/animations';

      // Mobile menu
      const toggle = document.getElementById('menu-toggle');
      const menu   = document.getElementById('mobile-menu');
      toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));

      // Cart badge
      async function updateCartBadge() {
        const { getCartCount } = await import('@/lib/cart');
        const count = getCartCount();
        const badge = document.getElementById('cart-badge');
        if (!badge) return;
        if (count > 0) {
          badge.textContent = String(count);
          badge.classList.remove('hidden');
        } else {
          badge.classList.add('hidden');
        }
      }
      updateCartBadge();
      window.addEventListener('cart:updated', updateCartBadge);

      // Smooth scroll + navbar
      const navbar = document.getElementById('navbar');
      initLenis();
      if (navbar) initNavbar(navbar);
    </script>
  </body>
</html>
